# Copy this file to `.env.prod` next to docker-compose.prod.yml and fill in
# real values. The compose file picks env vars up automatically.

# Django
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=your-domain.example.com,localhost,127.0.0.1
# Comma-separated origins (with scheme) for CSRF. Add a real domain once you
# have one, e.g. https://habits.example.com.
CSRF_TRUSTED_ORIGINS=

# Postgres
POSTGRES_DB=habithamster
POSTGRES_USER=habithamster
POSTGRES_PASSWORD=change-me-too

# Django superuser auto-created on first boot via createsuperuser --noinput.
DJANGO_SUPERUSER_USERNAME=change-me-admin-user
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password
DJANGO_SUPERUSER_EMAIL=admin@example.com
